# Copia este archivo a ".env" y completa tus datos reales.

PORT=3000

# URL publica donde va a vivir el sitio (Mercado Pago la necesita para los redirects
# y el webhook). En local podes dejar localhost, pero Mercado Pago no puede notificar
# a localhost: para probar el webhook necesitas exponer tu maquina con ngrok o similar,
# o probar directo en un hosting con URL publica.
BASE_URL=http://localhost:3000

# Access Token de Mercado Pago. Empeza con uno de PRUEBA (TEST-...) que se genera
# gratis en tu panel de desarrollador de Mercado Pago:
# https://www.mercadopago.com.ar/developers/panel
MP_ACCESS_TOKEN=TEST-000000000000-000000-00000000000000000000000000000000-000000000

# Token simple para proteger el endpoint de administracion (cambiar precios/parametros).
# Elegi cualquier clave larga y secreta.
ADMIN_TOKEN=cambiar-esta-clave-larga-y-secreta
